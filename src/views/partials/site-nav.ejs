<% const a = typeof active !== 'undefined' ? active : ''; %>
<div class="site-topbar d-none d-md-block">
  <div class="container d-flex justify-content-between align-items-center py-1 small">
    <span>Free shipping on orders over €50 · 30-day returns</span>
    <span><a href="/contact">Help center</a></span>
  </div>
</div>
<nav class="navbar navbar-expand-lg site-navbar sticky-top">
  <div class="container">
    <a class="navbar-brand site-brand" href="/">
      <span class="site-brand-mark" aria-hidden="true"></span>
      <%= typeof siteName !== 'undefined' ? siteName : 'NorthTrade Mobile' %>
    </a>
    <button
      class="navbar-toggler border-0 shadow-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-2">
        <li class="nav-item">
          <a class="nav-link px-lg-3 <%= a === 'home' ? 'active' : '' %>" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-lg-3 <%= a === 'shop' ? 'active' : '' %>" href="/shop">Shop</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-lg-3 <%= a === 'about' ? 'active' : '' %>" href="/about">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-lg-3 <%= a === 'contact' ? 'active' : '' %>" href="/contact">Contact</a>
        </li>
      </ul>
      <div class="d-flex align-items-center gap-2">
        <a class="btn btn-site-outline btn-sm d-none d-sm-inline-flex" href="/shop">Browse catalog</a>
        <a class="btn btn-site-primary btn-sm" href="/contact">Support</a>
      </div>
    </div>
  </div>
</nav>
