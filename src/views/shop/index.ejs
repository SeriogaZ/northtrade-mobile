<%- include('../partials/layout-head', { title, active }) %>
<%- include('../partials/site-nav', { active }) %>

<main class="shop-surface flex-grow-1 py-4 py-lg-5">
  <div class="container">
    <header class="mb-4 pb-3 border-bottom border-secondary border-opacity-25">
      <p class="site-eyebrow site-eyebrow--dark mb-2">Catalog</p>
      <h1 class="site-section-title display-6 mb-2">Shop all devices</h1>
      <p class="text-secondary col-lg-8 mb-0">
        Browse by category, search the lineup, and manage products and categories in one place. Pricing and images update
        instantly across the store.
      </p>
    </header>

    <div id="shop-alert" class="alert d-none border-0 shadow-sm" role="alert"></div>

    <section id="browse" class="card shop-card mb-4">
      <div class="card-body p-4">
        <h2 class="h5 card-title mb-3">Find products</h2>
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label fw-medium" for="category-filter">Category</label>
            <select id="category-filter" class="form-select form-select-lg" aria-label="Filter by category"></select>
          </div>
          <div class="col-md-5">
            <label class="form-label fw-medium" for="search-q">Search</label>
            <input
              id="search-q"
              type="search"
              class="form-control form-control-lg"
              placeholder="Model, brand, keyword…"
              autocomplete="off"
            />
          </div>
          <div class="col-md-3 d-flex gap-2">
            <button type="button" id="btn-search" class="btn btn-site-primary flex-grow-1 btn-lg">Search</button>
            <button type="button" id="btn-clear-search" class="btn btn-outline-secondary btn-lg">Clear</button>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-4">
      <h2 class="h5 mb-3">Product grid</h2>
      <div id="records-container" class="table-responsive shop-card bg-white rounded-4 p-2"></div>
    </section>

    <div class="row g-4">
      <div class="col-lg-6">
        <section class="card shop-card h-100">
          <div class="card-body p-4">
            <h2 class="h5 card-title">Add product</h2>
            <form id="form-add-record" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label" for="add-category">Category</label>
                <select id="add-category" name="category_id" class="form-select" required></select>
              </div>
              <div class="mb-3">
                <label class="form-label" for="add-name">Product name</label>
                <input id="add-name" name="name" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label" for="add-price">Price (€)</label>
                <input id="add-price" name="price" type="number" step="0.01" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label" for="add-image">Photo</label>
                <input id="add-image" name="image" type="file" class="form-control" accept="image/*" />
                <div class="form-text">JPG, PNG, or GIF · up to 5 MB</div>
              </div>
              <button type="submit" class="btn btn-site-primary">Add to catalog</button>
            </form>
          </div>
        </section>
      </div>
      <div class="col-lg-6">
        <section class="card shop-card h-100 border-primary border-opacity-25" id="edit-card" style="display: none">
          <div class="card-body p-4">
            <h2 class="h5 card-title">Edit product</h2>
            <form id="form-edit-record" enctype="multipart/form-data">
              <input type="hidden" id="edit-record-id" name="record_id" />
              <div class="mb-3">
                <label class="form-label" for="edit-category">Category</label>
                <select id="edit-category" name="category_id" class="form-select" required></select>
              </div>
              <div class="mb-3">
                <label class="form-label" for="edit-name">Product name</label>
                <input id="edit-name" name="name" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label" for="edit-price">Price (€)</label>
                <input id="edit-price" name="price" type="number" step="0.01" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label" for="edit-image">Replace photo</label>
                <input id="edit-image" name="image" type="file" class="form-control" accept="image/*" />
              </div>
              <div class="mb-3" id="edit-current-image-wrap"></div>
              <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-site-primary">Save changes</button>
                <button type="button" id="btn-cancel-edit" class="btn btn-outline-secondary">Cancel</button>
              </div>
            </form>
          </div>
        </section>
      </div>
    </div>

    <section class="card shop-card mt-4">
      <div class="card-body p-4">
        <h2 class="h5 card-title">Categories</h2>
        <p class="text-secondary small">Organize the catalog. You can only remove a category when no products use it.</p>
        <div class="row g-3">
          <div class="col-md-8 col-lg-6">
            <form id="form-add-category" class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-end">
              <div class="flex-grow-1">
                <label class="form-label" for="new-category-name">New category</label>
                <input id="new-category-name" type="text" class="form-control" placeholder="e.g. Accessories" required />
              </div>
              <button type="submit" class="btn btn-outline-primary">Add</button>
            </form>
          </div>
          <div class="col-12">
            <div id="categories-list" class="list-group list-group-flush rounded-3 border"></div>
          </div>
        </div>
      </div>
    </section>
  </div>
</main>

<script src="/js/phone-shop.js" defer></script>
<%- include('../partials/site-footer') %>
